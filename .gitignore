# OpenCode iOS Client - .gitignore

# Local dev checkouts (not part of this repo)
opencode-official/

# Python tooling (scripts/resize_icon.py)
.venv/

# Xcode
build/
DerivedData/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
*.xccheckout
*.moved-aside
*.xcuserstate
*.xcscmblueprint

# Local build logs (should not be committed)
OpenCodeClient/build_log*.txt

# Swift Package Manager
.build/
.swiftpm/
# Package.resolved is committed for Xcode Cloud (automatic resolution disabled in CI).

# CocoaPods
Pods/
*.xcworkspace
!default.xcworkspace
!**/*.xcodeproj/project.xcworkspace/
!**/*.xcodeproj/project.xcworkspace/**

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Thumbnails
Thumbs.db

# IDE
.idea/
*.swp
*.swo
*~

# Security notes (local only)
docs/security.md

# Environment variables (contains credentials)
.env

# Local design drafts and temporary artifacts
tmp_*

# Markdown Web Preview 子项目的 PRD / RFC 已合并进主 PRD §4.3.5 / 主 RFC §7.5；
# 完整决策过程保留在磁盘但不再随仓库分发。
docs/Markdown_Web_Preview_PRD.md
docs/Markdown_Web_Preview_RFC.md
